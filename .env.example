# Backend API base URL. Must point to the /api root (e.g. https://api.example.com/api or http://YOUR_IP:3001/api).
# If you omit /api, it is appended automatically.
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Google Maps: required for the plot map screen (react-native-maps).
# Get a key at https://console.cloud.google.com/ (Maps SDK for Android / iOS).
# Restrict by app package/bundle ID in production.
EXPO_PUBLIC_GOOGLE_MAPS_APIKEY=
